{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "group:all", ":npm", ":semanticCommits", ":enableVulnerabilityAlertsWithLabel(security)", ":assignee(s-theo)", ":maintainLockFilesWeekly"],
  "labels": ["dependencies"],
  "packageRules": [
    { "bumpVersion": "prerelease", "matchPackageNames": ["vitepress"] },
    {
      "description": "Hold TypeScript 7 upgrades for manual approval",
      "matchPackageNames": ["typescript"],
      "matchCurrentVersion": "<7",
      "matchNewValue": "/^[~^]?7\\./",
      "groupName": "TypeScript 7",
      "groupSlug": "typescript-7",
      "dependencyDashboardApproval": true
    }
  ],
  "rangeStrategy": "bump",
  "timezone": "Asia/Shanghai"
}
